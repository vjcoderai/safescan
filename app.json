{
  "expo": {
    "name": "SafeScan",
    "slug": "safescan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.safescan.app",
      "infoPlist": {
        "NSCameraUsageDescription": "SafeScan uses the camera to scan documents.",
        "NSPhotoLibraryUsageDescription": "SafeScan reads photos to convert them to PDF.",
        "NSPhotoLibraryAddUsageDescription": "SafeScan saves scanned documents.",
        "NSMicrophoneUsageDescription": "Required by the camera API."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.safescan.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": { "favicon": "./assets/favicon.png" },
    "plugins": [
      ["expo-camera", { "cameraPermission": "SafeScan uses the camera to scan documents." }],
      ["expo-image-picker", { "photosPermission": "SafeScan reads photos to convert them to PDF." }]
    ]
  }
}
